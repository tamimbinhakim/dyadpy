{
  "name": "@dyadpy/ts",
  "version": "0.3.0",
  "description": "Deprecated shim. @dyadpy/ts has been renamed to causeway-ts — install that instead.",
  "keywords": [
    "deprecated",
    "causeway"
  ],
  "homepage": "https://github.com/tamimbinhakim/causeway#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/causeway/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/causeway.git",
    "directory": "packages/dyadpy-ts"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sse": {
      "types": "./dist/sse.d.ts",
      "import": "./dist/sse.js",
      "require": "./dist/sse.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "causeway-ts": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsup": "8.5.1"
  },
  "engines": {
    "node": ">=20"
  }
}
