{
  "name": "@dyadpy/svelte",
  "version": "0.3.0",
  "description": "Deprecated shim. @dyadpy/svelte has been renamed to @causewayjs/svelte — install that instead.",
  "keywords": [
    "deprecated",
    "causeway"
  ],
  "homepage": "https://github.com/tamimbinhakim/causeway#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/causeway/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/causeway.git",
    "directory": "packages/dyadpy-svelte"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@causewayjs/svelte": "^0.1.1-alpha.0"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "svelte": "5.55.5",
    "tsup": "8.5.1"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0 <6"
  },
  "engines": {
    "node": ">=20"
  }
}
